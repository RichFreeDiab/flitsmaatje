default_platform(:ios)

APP_BUNDLE_ID = "nl.readvanes.flitsmaatje".freeze
WIDGET_BUNDLE_ID = "nl.readvanes.flitsmaatje.widget".freeze
APP_GROUP_ID = "group.nl.readvanes.flitsmaatje".freeze

def with_asc_api_token
  require "spaceship/connect_api"
  require "base64"
  require "tmpdir"

  key_path = File.join(Dir.tmpdir, "AuthKey_#{ENV.fetch('ASC_KEY_ID')}.p8")
  File.binwrite(key_path, Base64.strict_decode64(ENV.fetch("ASC_KEY_CONTENT")))
  token = Spaceship::ConnectAPI::Token.create(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    filepath: key_path,
    duration: 1200,
    in_house: false
  )
  Spaceship::ConnectAPI.token = token
  yield
ensure
  File.delete(key_path) if defined?(key_path) && key_path && File.exist?(key_path)
end

def revoke_all_distribution_certs!
  with_asc_api_token do
    certs = Spaceship::ConnectAPI::Certificate.all
    dist = certs.select { |c| c.certificate_type.to_s.include?("DISTRIBUTION") }
    UI.important("Revoking #{dist.count} distribution certificate(s)")
    dist.each do |cert|
      UI.important("  -> #{cert.id} (#{cert.certificate_type})")
      Spaceship::ConnectAPI.delete_certificate(certificate_id: cert.id)
    end
  end
end

def ensure_app_group_entity!
  # App Group is aangemaakt in Apple Developer Portal (group.nl.readvanes.flitsmaatje).
  UI.success("App Group assumed present: #{APP_GROUP_ID}")
end

def ensure_bundle_id!(identifier:, name:)
  with_asc_api_token do
    existing = Spaceship::ConnectAPI::BundleId.all(filter: { identifier: identifier }).first
    if existing
      UI.success("Bundle ID exists: #{identifier}")
      return existing
    end

    created = Spaceship::ConnectAPI::BundleId.create(
      name: name,
      identifier: identifier,
      platform: "IOS"
    )
    UI.success("Created Bundle ID: #{identifier}")
    created
  end
end

def link_app_group!(bundle_identifier:)
  settings = [{
    key: "APP_GROUP_IDS",
    options: [{ key: APP_GROUP_ID, enabled: true }]
  }]

  with_asc_api_token do
    bundle = Spaceship::ConnectAPI::BundleId.all(filter: { identifier: bundle_identifier }).first
    UI.user_error!("Bundle ID not found: #{bundle_identifier}") unless bundle

    caps = Spaceship::ConnectAPI::BundleIdCapability.all(bundle_id_id: bundle.id)
    caps.select { |c| c.capability_type.to_s == "APP_GROUPS" }.each(&:delete!)

    Spaceship::ConnectAPI::BundleIdCapability.create(
      bundle_id_id: bundle.id,
      capability_type: Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS,
      settings: settings
    )

    UI.success("App Group #{APP_GROUP_ID} linked to #{bundle_identifier}")
  end
end

def prepare_carplay_signing!
  ensure_app_group_entity!
  ensure_bundle_id!(identifier: WIDGET_BUNDLE_ID, name: "FlitsMaatje Widget")
  link_app_group!(bundle_identifier: APP_BUNDLE_ID)
  link_app_group!(bundle_identifier: WIDGET_BUNDLE_ID)
end

def ensure_app_store_record!
  with_asc_api_token do
    bundle = Spaceship::ConnectAPI::BundleId.all(filter: { identifier: APP_BUNDLE_ID }).first
    UI.user_error!("Bundle ID missing: #{APP_BUNDLE_ID}") unless bundle

    existing = Spaceship::ConnectAPI::App.all(filter: { bundleId: APP_BUNDLE_ID })
    if existing.any?
      UI.success("App Store Connect record exists for #{APP_BUNDLE_ID}")
      return
    end

    Spaceship::ConnectAPI::App.create(
      name: "FlitsMaatje",
      bundle_id: bundle.id,
      primary_locale: "nl-NL",
      sku: "flitsmaatje-ios",
      platforms: ["IOS"]
    )
    UI.success("Created App Store Connect app: FlitsMaatje")
  end
end

platform :ios do
  desc "Build en upload naar TestFlight (draait op GitHub Actions — geen Mac nodig)"
  lane :beta do
    setup_ci if ENV["CI"]
    api_key = asc_api_key

    prepare_carplay_signing!

    match(
      type: "appstore",
      api_key: api_key,
      app_identifier: [APP_BUNDLE_ID, WIDGET_BUNDLE_ID],
      readonly: false,
      force: true,
      git_basic_authorization: match_git_auth
    )

    update_project_provisioning(
      xcodeproj: "FlitsMaatje.xcodeproj",
      target_filter: "FlitsMaatje",
      profile: ENV["sigh_#{APP_BUNDLE_ID}_appstore_profile-path"],
      build_configuration: "Release"
    )

    update_project_provisioning(
      xcodeproj: "FlitsMaatje.xcodeproj",
      target_filter: "FlitsMaatjeWidget",
      profile: ENV["sigh_#{WIDGET_BUNDLE_ID}_appstore_profile-path"],
      build_configuration: "Release"
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "FlitsMaatje.xcodeproj",
      targets: ["FlitsMaatje"],
      build_configurations: ["Release"],
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["sigh_#{APP_BUNDLE_ID}_appstore_profile-name"],
      bundle_identifier: APP_BUNDLE_ID
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "FlitsMaatje.xcodeproj",
      targets: ["FlitsMaatjeWidget"],
      build_configurations: ["Release"],
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["sigh_#{WIDGET_BUNDLE_ID}_appstore_profile-name"],
      bundle_identifier: WIDGET_BUNDLE_ID
    )

    increment_build_number(
      xcodeproj: "FlitsMaatje.xcodeproj",
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s
    )

    build_app(
      scheme: "FlitsMaatje",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      export_options: {
        provisioningProfiles: {
          APP_BUNDLE_ID => ENV["sigh_#{APP_BUNDLE_ID}_appstore_profile-name"],
          WIDGET_BUNDLE_ID => ENV["sigh_#{WIDGET_BUNDLE_ID}_appstore_profile-name"]
        },
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"]
      },
      xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Manual"
    )

    ensure_app_store_record!

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["FLITSMAATJE_CHANGELOG"] || "CarPlay Dashboard-widget + achtergrondwaarschuwingen"
    )
  end

  private_lane :match_git_auth do
    ENV["MATCH_GIT_BASIC_AUTHORIZATION"] || (
      token = ENV["GITHUB_TOKEN"] || ENV["GH_TOKEN"]
      token ? Base64.strict_encode64("x-access-token:#{token}") : nil
    )
  end

  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 1200,
      in_house: false
    )
  end
end

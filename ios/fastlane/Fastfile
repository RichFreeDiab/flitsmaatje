default_platform(:ios)

platform :ios do
  desc "Maak app-records aan in App Store Connect (eenmalig)"
  lane :setup_app do
    api_key = asc_api_key
    produce(
      api_key: api_key,
      app_identifier: "nl.readvanes.flitsmaatje",
      app_name: "FlitsMaatje",
      language: "nl-NL",
      app_version: "1.0",
      sku: "flitsmaatje-ios",
      team_id: ENV["APPLE_TEAM_ID"],
      enable_services: { app_group: "on" }
    )
    produce(
      api_key: api_key,
      app_identifier: "nl.readvanes.flitsmaatje.widget",
      app_name: "FlitsMaatjeWidget",
      skip_itc: true,
      team_id: ENV["APPLE_TEAM_ID"],
      enable_services: { app_group: "on" }
    )
  end

  desc "Build en upload naar TestFlight (draait op GitHub Actions — geen Mac nodig)"
  lane :beta do
    setup_ci if ENV["CI"]
    api_key = asc_api_key
    revoke_extra_distribution_certs if ENV["CI"]
    match_opts = {
      type: "appstore",
      api_key: api_key,
      readonly: false,
      git_basic_authorization: match_git_auth
    }

    match(**match_opts, app_identifier: "nl.readvanes.flitsmaatje")
    update_project_provisioning(
      xcodeproj: "FlitsMaatje.xcodeproj",
      target_filter: "FlitsMaatje",
      profile: ENV["sigh_nl.readvanes.flitsmaatje_appstore_profile-path"],
      build_configuration: "Release"
    )

    match(**match_opts, app_identifier: "nl.readvanes.flitsmaatje.widget")
    update_project_provisioning(
      xcodeproj: "FlitsMaatje.xcodeproj",
      target_filter: "FlitsMaatjeWidget",
      profile: ENV["sigh_nl.readvanes.flitsmaatje.widget_appstore_profile-path"],
      build_configuration: "Release"
    )

    increment_build_number(
      xcodeproj: "FlitsMaatje.xcodeproj",
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s
    )

    build_app(
      scheme: "FlitsMaatje",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Manual"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["FLITSMAATJE_CHANGELOG"] || "Nieuwe build"
    )
  end

  private_lane :revoke_extra_distribution_certs do
    require "spaceship/connect_api"

    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
      duration: 1200,
      in_house: false
    )
    Spaceship::ConnectAPI.token = token
    certs = Spaceship::ConnectAPI::Certificate.all(
      filter: {
        certificateType: Spaceship::ConnectAPI::Certificate::CertificateType::IOS_DISTRIBUTION
      }
    )
    certs.each do |cert|
      UI.important("Revoking distribution certificate #{cert.id}")
      cert.delete
    end
  end

  private_lane :match_git_auth do
    ENV["MATCH_GIT_BASIC_AUTHORIZATION"] || (
      token = ENV["GITHUB_TOKEN"] || ENV["GH_TOKEN"]
      token ? Base64.strict_encode64("x-access-token:#{token}") : nil
    )
  end

  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 1200,
      in_house: false
    )
  end
end
